{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENT.md"],
  "permission": {
    "read": {
      "*": "allow",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/credentials.json": "deny",
      "**/secrets/**": "deny",
      "*.env": "deny",
      "*.env.*": "deny"
    },
    "bash": {
      "*": "allow",
      "git commit": "ask",
      "git commit *": "ask",
      "git push": "ask",
      "git push *": "ask",
      "git push --force *": "ask",
      "git rebase *": "ask",
      "git reset --hard *": "ask"
    },
    "edit": "ask",
    "glob": "allow",
    "list": "allow",
    "grep": "allow",
    "external_directory": "allow"
  }
}
